# Optional: absolute API origin (otherwise the client uses same-origin `/api/*`).
# VITE_API_BASE_URL=http://127.0.0.1:4000

# In `npm run dev`, fetching `/api/translations` is OFF by default (no backend required).
# Set to "false" when the API is running (e.g. `cd server && npm run dev` on port 4000).
# VITE_SKIP_SERVER_I18N=false
#
# Production / static: set to "true" to never request the API.
# VITE_SKIP_SERVER_I18N=true

# Google Analytics 4 (production only; leave empty in local dev)
# Example: VITE_GA4_MEASUREMENT_ID=G-ABC123XYZ9
# VITE_GA4_MEASUREMENT_ID=
#
# Optional: sends debug_mode flag to GA events (useful when validating with DebugView)
# VITE_GA4_DEBUG_MODE=false

