# Optional: absolute API origin (otherwise the client uses same-origin `/api/*`).
# VITE_API_BASE_URL=http://127.0.0.1:4000

# Set to "true" to skip fetching `/api/translations` (pure static hosting).
# VITE_SKIP_SERVER_I18N=false

# Google Analytics 4 Measurement ID (production only tracking).
# Example: VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_GA_MEASUREMENT_ID=
