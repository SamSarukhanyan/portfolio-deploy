# Portfolio i18n API (Express). Keep a SEPARATE DB_NAME from other apps (e.g. social_network).

PORT=4004
NODE_ENV=production

# Browser origins allowed to call this API (comma-separated). Add your domain + Vite dev if needed.
CORS_ORIGIN=http://localhost:5173,https://samsarukhanyan.com

# --- MySQL (same server/instance as other projects is fine; use a NEW database name) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=samsarukhanyan_portfolio
DB_USER=app_user_prod
DB_PASSWORD=

# Not used by this small API today — only add if you extend the server with auth.
# JWT_SECRET=
